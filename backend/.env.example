# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/multiagent_pm"

# Ollama Configuration (legacy - not currently used)
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_NUM_PREDICT=2000
OLLAMA_NUM_CTX=4096

# Server Configuration
PORT=5555
NODE_ENV="development"

# Multi-Agent System Configuration
USE_MULTI_AGENT_WORKFLOW="true"

# ============================================
# AI Service Selection
# ============================================
# Set AI_SERVICE to 'gemini' (default) or 'github' to choose the provider.
# Only the key for the selected provider is required at startup.
# You can switch providers at runtime via the Dashboard without restarting.
# ============================================
AI_SERVICE=gemini

# ============================================
# Google Gemini API Configuration
# ============================================
# Required when AI_SERVICE=gemini
# Get a free key at: https://aistudio.google.com/apikey
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# GitHub Models API Configuration
# ============================================
# Required when AI_SERVICE=github
# Get a token at: https://github.com/settings/tokens (needs no special scopes)
# Endpoint and model can be left as defaults unless you have a custom deployment.
# ============================================
GITHUB_MODELS_API_KEY=your_github_token_here
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODELS_MODEL=gpt-4o

# ============================================
# Rate Limit Configuration (optional)
# ============================================
# All values have sensible defaults shown below.
# Override to tune for your API plan/tier.
# ============================================

# Gemini rate limits (free tier defaults)
# GEMINI_RPM=4           # max requests per minute
# GEMINI_RPD=18          # max requests per day (leave 2 buffer before hitting 20)
# GEMINI_INTERVAL_MS=15000   # min ms between requests
# GEMINI_MAX_RETRIES=5

# Groq rate limits
# GROQ_INTERVAL_MS=500
# GROQ_MAX_RETRIES=5
# GROQ_MAX_TOKENS=4096   # reserved per request against the TPM budget; lower = fewer 429s on free tier (12k TPM)

# GitHub Models rate limits
# GITHUB_INTERVAL_MS=500
# GITHUB_MAX_RETRIES=3

# NVIDIA rate limits
# NVIDIA_INTERVAL_MS=500
# NVIDIA_MAX_RETRIES=5

# Ollama
# OLLAMA_GENERATE_TIMEOUT_MS=480000   # already supported
