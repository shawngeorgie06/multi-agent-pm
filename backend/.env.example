# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/multiagent_pm"

# Ollama Configuration (legacy - not currently used)
OLLAMA_API_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2:3b"
OLLAMA_NUM_PREDICT=2000
OLLAMA_NUM_CTX=4096

# Server Configuration
PORT=5555
NODE_ENV="development"

# Multi-Agent System Configuration
USE_MULTI_AGENT_WORKFLOW="true"

# ============================================
# REQUIRED: Google Gemini API Configuration
# ============================================
# 1. Get your FREE API key from: https://aistudio.google.com/apikey
# 2. Replace 'your_gemini_api_key_here' below with your actual key
# 3. Restart backend server after updating
#
# Example: GEMINI_API_KEY=AIzaSyAbc123YourActualKey456DefGhi789
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here
