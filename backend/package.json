{
  "name": "multi-agent-pm-backend",
  "version": "0.1.0",
  "description": "Backend for Multi-Agent Project Manager System",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "test:phase1": "jest __tests__/phase1 --coverage",
    "test:phase2": "jest __tests__/phase2 --coverage",
    "test:phase3": "jest __tests__/phase3 --coverage",
    "test:phase4": "jest __tests__/phase4 --coverage",
    "test:bench": "jest __tests__/benchmarks --testTimeout=60000",
    "test:cli": "tsx src/cli.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.7.0",
    "axios": "^1.6.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "jest": "^30.2.0",
    "prisma": "^5.7.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
